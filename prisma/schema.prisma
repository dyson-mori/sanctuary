generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @unique @default(uuid())

  firstname String
  lastname  String
  nickname  String
  password  String
  photo     String

  // creator Creator?
  post Post[]
  hide Hide[]

  @@map("users")
}

